---
export interface Props {
	title: string;
}

const { title } = Astro.props;
---

<!DOCTYPE html>
<html lang="pt-BR" data-theme="dark">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>{title}</title>
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=JetBrains+Mono:ital,wght@0,100..800;1,100..800&family=Syne:wght@400;600;700;800&display=swap" rel="stylesheet" />
  <link rel="stylesheet" href="/assets/css/style.css">
</head>
<body>
  <div id="cursor"></div>
  <div id="cursor-ring"></div>
  <canvas id="bg-canvas"></canvas>
  <div id="scanlines"></div>
  <div class="noise"></div>

  <div class="wrapper">
    <nav>
      <div class="nav-logo"><span>//</span> dev.portfolio</div>
      <ul class="nav-links">
        <li><a href="#about">Sobre</a></li>
        <li><a href="#projects">Projetos</a></li>
        <li><a href="#articles">Artigos</a></li>
        <li><a href="#videos">Videos</a></li>
        <li><a href="#contact">Contato</a></li>
      </ul>
      <div class="nav-right">
        <button class="theme-btn" id="themeToggle" onclick="toggleTheme()">☀ Light</button>
      </div>
    </nav>

    <slot />

    <footer>
      <span>// <span style="color:var(--accent)">dev.portfolio</span> — construído com Astro & obsessão por detalhes</span>
      <span style="color:var(--txt-dim)">MIT License · <span id="year"></span></span>
    </footer>
  </div>
  <script is:inline src="/assets/js/main.js"></script>
</body>
</html>
